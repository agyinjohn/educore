# Test Environment Variables
NODE_ENV=test
PORT=3000

# MongoDB (test database)
MONGO_URI=mongodb://localhost:27017/educore-test
MONGODB_URI=mongodb://localhost:27017/educore-test

# Redis
REDIS_URI=redis://localhost:6379/1
REDIS_URL=redis://localhost:6379/1

# JWT
JWT_SECRET=test-jwt-secret-key-do-not-use-in-production
JWT_ACCESS_SECRET=test-access-secret-key
JWT_REFRESH_SECRET=test-refresh-secret-key
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Service URLs
AUTH_SERVICE_URL=http://localhost:4001
TENANT_SERVICE_URL=http://localhost:4002
STUDENT_SERVICE_URL=http://localhost:4003
ACADEMIC_SERVICE_URL=http://localhost:4004
API_GATEWAY_URL=http://localhost:4000

# Service Ports
AUTH_SERVICE_PORT=4001
TENANT_SERVICE_PORT=4002
STUDENT_SERVICE_PORT=4003
ACADEMIC_SERVICE_PORT=4004
API_GATEWAY_PORT=4000

# MFA
MFA_WINDOW=1
MFA_STEP=30

# Password Reset
PASSWORD_RESET_EXPIRY=3600

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
