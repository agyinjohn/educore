# MongoDB
MONGO_URI=mongodb://localhost:27017/educore

# Redis
REDIS_URI=redis://localhost:6379

# JWT
JWT_SECRET=your-dev-secret-key-change-in-production

# Node Environment
NODE_ENV=development

# Service Ports
PORT=3000

# Services URLs
AUTH_SERVICE_URL=http://localhost:3000
TENANT_SERVICE_URL=http://localhost:3001
STUDENT_SERVICE_URL=http://localhost:3002
ACADEMIC_SERVICE_URL=http://localhost:3003

# Email Service
RESEND_API_KEY=your-resend-key

# SMS Service
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token

# File Storage
AWS_S3_BUCKET=educore-bucket
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-key
AWS_SECRET_ACCESS_KEY=your-secret
