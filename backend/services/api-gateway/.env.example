PORT=4000
NODE_ENV=development

# JWT — must match auth-service
JWT_ACCESS_SECRET=change_this_to_a_strong_random_secret_min_64_chars

# Downstream service URLs
AUTH_SERVICE_URL=http://localhost:4001
TENANT_SERVICE_URL=http://localhost:4002
STUDENT_SERVICE_URL=http://localhost:4003
ACADEMIC_SERVICE_URL=http://localhost:4004
FINANCE_SERVICE_URL=http://localhost:4005
NOTIFICATION_SERVICE_URL=http://localhost:4006
ANALYTICS_SERVICE_URL=http://localhost:4008
REPORT_SERVICE_URL=http://localhost:4009

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10
