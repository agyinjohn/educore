PORT=4001
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/educore_auth

# JWT — use strong random secrets (min 64 chars each)
JWT_ACCESS_SECRET=change_this_to_a_strong_random_secret_min_64_chars
JWT_REFRESH_SECRET=change_this_to_a_different_strong_random_secret_min_64_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Password reset token expiry (seconds)
PASSWORD_RESET_EXPIRES_SEC=1800

# Account lockout
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MS=1800000

# TOTP issuer name shown in authenticator apps
TOTP_ISSUER=EduCore
