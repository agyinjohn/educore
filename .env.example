# MongoDB Configuration
MONGO_USERNAME=admin
MONGO_PASSWORD=password
MONGO_DATABASE=educore

# JWT Configuration — every service must verify with the same secret
# auth-service signs with. Set one value; docker-compose falls back to
# JWT_SECRET for JWT_ACCESS_SECRET if you only set this one.
JWT_SECRET=educore-secret-key-change-in-production
JWT_ACCESS_SECRET=educore-secret-key-change-in-production

# Email Configuration (Optional - for Notification Service)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=test@example.com
SMTP_PASS=password

# AI Service Configuration (Optional)
OPENAI_API_KEY=

# Node Environment
NODE_ENV=development

# Service Ports
API_GATEWAY_PORT=3000
AUTH_SERVICE_PORT=4000
STUDENT_SERVICE_PORT=4001
ACADEMIC_SERVICE_PORT=4002
FINANCE_SERVICE_PORT=4003
NOTIFICATION_SERVICE_PORT=4004
TENANT_SERVICE_PORT=4005
ANALYTICS_SERVICE_PORT=4008
REPORT_SERVICE_PORT=4009
AI_SERVICE_PORT=4011
CHATBOT_SERVICE_PORT=4010
